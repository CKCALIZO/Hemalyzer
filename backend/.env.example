# ===========================================
# Hemalyzer Backend Environment Variables
# ===========================================
# Copy this file to .env for local development
# For Render: Set these in the Render dashboard under Environment

# ===========================================
# DEPLOYMENT MODE
# ===========================================
# Set to 'production' for deployed environments
FLASK_ENV=development

# ===========================================
# COLAB MODEL CONFIGURATION
# ===========================================
# When set, the backend will use the Colab-hosted model instead of loading locally
# Get this URL from the ngrok output in your Colab notebook
# Example: https://abc123.ngrok-free.app
COLAB_MODEL_URL=

# API key for authenticating with the Colab model server
# Must match the API_KEY in your Colab notebook
COLAB_API_KEY=hemalyzer-colab-2024

# ===========================================
# LOCAL MODEL CONFIGURATION (when not using Colab)
# ===========================================
# Path to the ConvNeXt model file (relative to backend directory)
MODEL_PATH=best_leukemia_model.pth

# ===========================================
# YOLO DETECTION API (Roboflow)
# ===========================================
# Roboflow API key for blood cell detection
ROBOFLOW_API_KEY=your_roboflow_api_key_here

# ===========================================
# CORS CONFIGURATION
# ===========================================
# Allowed origins for CORS (comma-separated)
# Example: https://your-app.netlify.app,http://localhost:5173
CORS_ORIGINS=*
